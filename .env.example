# Copiar a .env y rellenar valores reales
OPENAI_API_KEY=sk-...

# Modelo por defecto (chat)
OPENAI_MODEL=gpt-4o-mini

# Ciudad por defecto para clima / hora si el usuario no especifica otra
DEFAULT_CITY=Madrid

# API FastAPI (python -m asistente.api)
API_HOST=0.0.0.0
API_PORT=8000

# Memoria de sesión (~45 min por defecto)
SESSION_TTL_SECONDS=2700
SESSION_MAX_TURN_PAIRS=12

# Memoria larga (RAG en disco)
MEMORY_DIR=./data/memory
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=8

# MQTT (domótica). Sin MQTT_BROKER_HOST no se publica nada.
MQTT_BROKER_HOST=192.168.1.10
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=casa
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CLIENT_ID=asistente-personal

# Zonas domóticas (coma). Deben coincidir con casa/<zona> en cada dispositivo.
# Un ESP32 puede cubrir varias zonas (varios topics); ejemplo tres luces.
# «Prender/apagar todas las luces» publica en cada zona listada (no vacía):
# MQTT_HOME_ZONES=living,comedor,patio
# MQTT_HOME_ZONES=
